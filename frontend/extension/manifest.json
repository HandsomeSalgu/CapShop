{
  "manifest_version": 3,
  "name": "SyncShopper",
  "version": "0.1.0",
  "description": "Analyze YouTube frames and show commerce product results.",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:8080/*", "https://www.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
